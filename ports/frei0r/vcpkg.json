{
  "name": "frei0r",
  "version": "2.5.1",
  "description": "Minimalistic plugin API for video effects (ArcForges fork)",
  "homepage": "https://github.com/ArcForgesLabs/frei0r",
  "license": "GPL-2.0-only",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "opencv": {
      "description": "Enable plugins dependent upon OpenCV",
      "dependencies": [
        {
          "name": "opencv",
          "features": ["contrib"]
        }
      ]
    },
    "cairo": {
      "description": "Enable plugins dependent upon Cairo",
      "dependencies": ["cairo"]
    }
  }
}
